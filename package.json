{
  "name": "tudu",
  "version": "0.1.3",
  "description": "A flashcard app with spaced repetition",
  "author": "limboy",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && dotenv -- electron-builder --mac",
    "preview": "vite preview",
    "start": "vite",
    "electron": "electron .",
    "lint": "tsc -b --noEmit",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "changelog": "node scripts/generate-changelog.cjs"
  },
  "build": {
    "appId": "me.limboy.tudu",
    "productName": "Tudu",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "minimumSystemVersion": "12.0",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "notarize": true
    },
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "dist/main.js",
      "dist/preload.mjs",
      "assets/icon.png",
      "!**/node_modules/**/*.{c,cpp,h,cc,hpp,gyp,gypi,md,markdown,txt,map}",
      "!**/node_modules/**/test/**",
      "!**/node_modules/**/docs/**",
      "!**/node_modules/**/.github/**",
      "!**/node_modules/prebuild-install/**",
      "!**/node_modules/node-abi/**",
      "!**/node_modules/napi-build-utils/**",
      "!**/node_modules/detect-libc/**",
      "!**/node_modules/tar-fs/**",
      "!**/node_modules/tar-stream/**",
      "!**/node_modules/simple-get/**",
      "!**/node_modules/simple-concat/**",
      "!**/node_modules/decompress-response/**",
      "!**/node_modules/mimic-response/**",
      "!**/node_modules/github-from-package/**",
      "!**/node_modules/expand-template/**",
      "!**/node_modules/pump/**",
      "!**/node_modules/rc/**",
      "!**/node_modules/ini/**",
      "!**/node_modules/strip-json-comments/**",
      "!**/node_modules/deep-extend/**",
      "!**/node_modules/minimist/**",
      "!**/node_modules/tunnel-agent/**",
      "!**/node_modules/mkdirp-classic/**",
      "!**/node_modules/chownr/**",
      "!**/node_modules/bl/**",
      "!**/node_modules/readable-stream/**",
      "!**/node_modules/string_decoder/**",
      "!**/node_modules/util-deprecate/**",
      "!**/node_modules/buffer/**",
      "!**/node_modules/base64-js/**",
      "!**/node_modules/ieee754/**",
      "!**/node_modules/fs-constants/**",
      "!**/node_modules/end-of-stream/**",
      "!**/node_modules/once/**",
      "!**/node_modules/wrappy/**",
      "!**/node_modules/safe-buffer/**",
      "!**/node_modules/semver/**"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "limboy",
        "repo": "tudu",
        "releaseType": "release"
      }
    ],
    "releaseInfo": {
      "releaseNotesFile": "RELEASENOTES.md"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ts-fsrs": "^5.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3"
  }
}
